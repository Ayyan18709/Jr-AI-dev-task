# ── Application ────────────────────────────────────────────────────────────────
APP_NAME="RAG Chatbot API"
APP_VERSION="1.0.0"
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── LLM ────────────────────────────────────────────────────────────────────────
LLM_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
LLM_MAX_NEW_TOKENS=512
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9
LLM_DEVICE=auto
LLM_LOAD_IN_4BIT=false

# ── Embeddings ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32

# ── Reranker ───────────────────────────────────────────────────────────────────
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
USE_RERANKER=true
RERANKER_TOP_K=5

# ── Retrieval ──────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
SEMANTIC_WEIGHT=0.6
BM25_WEIGHT=0.4
BM25_TOP_K=10

# ── Chunking ───────────────────────────────────────────────────────────────────
CHUNK_SIZE=400
CHUNK_OVERLAP=50

# ── Memory ─────────────────────────────────────────────────────────────────────
MEMORY_MAX_INTERACTIONS=10
MEMORY_SUMMARY_TRIGGER=5

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CACHE_TTL=3600
CACHE_ENABLED=true

# ── Paths ──────────────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=data/faiss_index
CV_UPLOAD_PATH=data/uploads
LOGS_PATH=logs
